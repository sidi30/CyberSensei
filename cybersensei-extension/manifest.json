{
  "manifest_version": 3,
  "name": "CyberSensei - Formation Cybersécurité",
  "short_name": "CyberSensei",
  "version": "1.0.0",
  "description": "Votre assistant cybersécurité : quiz quotidiens, glossaire, chat IA et suivi de progression.",
  "permissions": [
    "storage",
    "sidePanel",
    "alarms",
    "notifications"
  ],
  "host_permissions": [
    "https://cs-api.gwani.fr/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'none'; connect-src 'self' https://cs-api.gwani.fr"
  },
  "action": {
    "default_icon": {
      "16": "src/assets/icon-16.png",
      "48": "src/assets/icon-48.png",
      "128": "src/assets/icon-128.png"
    }
  },
  "side_panel": {
    "default_path": "src/popup/popup.html"
  },
  "background": {
    "service_worker": "src/background/background.js",
    "type": "module"
  },
  "icons": {
    "16": "src/assets/icon-16.png",
    "48": "src/assets/icon-48.png",
    "128": "src/assets/icon-128.png"
  }
}
