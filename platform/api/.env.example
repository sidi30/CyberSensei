# ==============================================
# CyberSensei Central Backend - Environment Variables
# ==============================================
# IMPORTANT: Copy this file to .env and fill in production values.
# NEVER commit .env to version control.

# ----------------------------------------------
# DATABASE - PostgreSQL
# ----------------------------------------------
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=cybersensei
POSTGRES_PASSWORD=           # REQUIRED: Use a strong password (32+ chars)
POSTGRES_DB=cybersensei_central

# ----------------------------------------------
# DATABASE - MongoDB
# ----------------------------------------------
MONGODB_URI=mongodb://localhost:27017/cybersensei_central

# ----------------------------------------------
# JWT AUTHENTICATION
# ----------------------------------------------
JWT_SECRET=                  # REQUIRED: Generate with `openssl rand -base64 64`
JWT_EXPIRES_IN=24h

# ----------------------------------------------
# DEFAULT ADMIN (created on first startup only)
# ----------------------------------------------
ADMIN_EMAIL=                 # REQUIRED: Admin email address
ADMIN_PASSWORD=              # REQUIRED: Min 12 chars, use strong password

# ----------------------------------------------
# APPLICATION
# ----------------------------------------------
PORT=3006
NODE_ENV=production
APP_URL=https://your-domain.com

# ----------------------------------------------
# CORS (comma-separated origins)
# ----------------------------------------------
CORS_ORIGINS=https://your-dashboard.com,https://your-m365-dashboard.com

# ----------------------------------------------
# M365 INTEGRATION
# ----------------------------------------------
M365_CLIENT_ID=              # Azure AD Application Client ID
M365_CLIENT_SECRET=          # Azure AD Application Client Secret
M365_REDIRECT_URI=           # OAuth callback URL
M365_TOKEN_ENCRYPTION_KEY=   # REQUIRED: Generate with `openssl rand -hex 32`
M365_DASHBOARD_URL=          # M365 dashboard URL for OAuth redirects

# ----------------------------------------------
# SMTP (email notifications)
# ----------------------------------------------
# Leave empty to log emails to console (dev mode)
SMTP_HOST=                   # e.g. smtp.resend.com, smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=                   # SMTP username / API key
SMTP_PASSWORD=               # SMTP password
SMTP_FROM=noreply@cybersensei.io

# ----------------------------------------------
# STRIPE (payment processing)
# ----------------------------------------------
# Leave empty to disable Stripe (manual billing mode)
STRIPE_SECRET_KEY=           # sk_live_... or sk_test_...
STRIPE_WEBHOOK_SECRET=       # whsec_...
STRIPE_STARTER_PRICE_ID=    # price_... (Starter plan monthly)
STRIPE_BUSINESS_PRICE_ID=   # price_... (Business plan monthly)

# ----------------------------------------------
# AI (optional)
# ----------------------------------------------
ANTHROPIC_API_KEY=           # Anthropic API key for AI features
AI_KEY_ENCRYPTION_SECRET=    # Encryption key for stored tenant API keys
