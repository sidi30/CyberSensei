# ============================================
# CyberSensei Agent — Environment Variables
# ============================================

# --- Database ---
POSTGRES_DB=cybersensei_db
POSTGRES_USER=cybersensei
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD

# --- Security ---
JWT_SECRET=CHANGE_ME_RANDOM_SECRET_MIN_32_CHARS

# --- Platform Sync ---
PLATFORM_API_URL=https://api.cybersensei.io
ACTIVATION_CODE=CS-XXXXXXXX

# --- AI Service ---
SEMANTIC_THRESHOLD=30
MODEL_PATH=/models/mistral-7b-instruct-v0.3.Q4_K_M.gguf

# --- Email (SMTP) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# --- Ports ---
AGENT_API_PORT=8080
AGENT_DASHBOARD_PORT=3005
AI_SERVICE_PORT=8000
