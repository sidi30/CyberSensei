# =============================================================================
# CyberSensei Agent — Variables d'environnement (On-Premise)
# =============================================================================
# Copier ce fichier vers docker/.env avant le docker compose up
# Modifier les valeurs selon l'environnement du client
# =============================================================================

# --- Database ---
POSTGRES_DB=cybersensei_db
POSTGRES_USER=cybersensei
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_32_CHARS

# --- Security ---
JWT_SECRET=CHANGE_ME_RANDOM_SECRET_MIN_32_CHARS

# --- Platform Sync (optionnel — connexion au SaaS CyberSensei) ---
PLATFORM_API_URL=https://api.cybersensei.io
ACTIVATION_CODE=CS-XXXXXXXX

# --- AI Service ---
SEMANTIC_THRESHOLD=30

# --- Email (SMTP) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# --- Teams (optionnel, --profile teams) ---
TEAMS_BOT_ID=
TEAMS_BOT_PASSWORD=
TEAMS_APP_ID=
TEAMS_APP_PASSWORD=
TEAMS_APP_TENANT_ID=

# --- Ports ---
AGENT_API_PORT=8080
AGENT_DASHBOARD_PORT=3005
AI_SERVICE_PORT=8000
POSTGRES_PORT=5432
