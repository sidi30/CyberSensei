# =============================================================================
# CyberSensei Platform — Variables d'environnement
# =============================================================================
# Copier ce fichier vers docker/.env avant le docker compose up
# En dev : les valeurs par défaut dans le compose suffisent (pas besoin de .env)
# En prod : copier, renommer en .env, changer TOUTES les valeurs marquées CHANGE_ME
# =============================================================================

# --- Database ---
POSTGRES_DB=cybersensei_central
POSTGRES_USER=cybersensei
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_32_CHARS
MONGO_USER=cybersensei
MONGO_PASSWORD=CHANGE_ME_STRONG_PASSWORD_32_CHARS
MONGO_DATABASE=cybersensei_central

# --- Security ---
JWT_SECRET=CHANGE_ME_RANDOM_SECRET_MIN_32_CHARS
JWT_EXPIRATION=24h

# --- Admin (créé au premier démarrage) ---
ADMIN_EMAIL=admin@cybersensei.io
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# --- Domain & Traefik (décommenter en prod) ---
# DOMAIN=gwani.fr
# TRAEFIK_NETWORK=coolify
# TRAEFIK_ENTRYPOINT=https
# TRAEFIK_TLS=true
# CORS_ORIGINS=https://cs-app.gwani.fr,https://cs-m365.gwani.fr,https://cybersensei.gwani.fr
# PUBLIC_BACKEND_URL=https://cs-api.gwani.fr
# M365_REDIRECT_URI=https://cs-m365.gwani.fr/m365/auth/callback
# GRAFANA_ROOT_URL=https://cs-monitoring.gwani.fr

# --- API Keys ---
ANTHROPIC_API_KEY=
HIBP_API_KEY=
ABUSEIPDB_API_KEY=

# --- Microsoft 365 ---
M365_CLIENT_ID=
M365_CLIENT_SECRET=
M365_REDIRECT_URI=
M365_TOKEN_ENCRYPTION_KEY=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Email (SMTP) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@cybersensei.io

# --- Teams (optionnel, --profile teams) ---
TEAMS_BOT_ID=
TEAMS_BOT_PASSWORD=
TEAMS_APP_ID=
TEAMS_APP_PASSWORD=
TEAMS_APP_TENANT_ID=

# --- AI Service (optionnel, --profile ai) ---
SEMANTIC_THRESHOLD=40

# --- Monitoring (optionnel, --profile monitoring) ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME

# --- Ports (dev — ignorés quand Traefik route en prod) ---
PLATFORM_API_PORT=3006
PLATFORM_DASHBOARD_PORT=5173
M365_DASHBOARD_PORT=5174
SCANNER_PORT=8003
WEBSITE_PORT=3002
POSTGRES_PORT=5432
MONGO_PORT=27017
