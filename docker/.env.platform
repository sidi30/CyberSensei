# ============================================
# CyberSensei Platform — Environment Variables
# ============================================

# --- Database ---
POSTGRES_DB=cybersensei_central
POSTGRES_USER=cybersensei
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
MONGO_DATABASE=cybersensei_central

# --- Security ---
JWT_SECRET=CHANGE_ME_RANDOM_SECRET_MIN_32_CHARS

# --- Admin ---
ADMIN_EMAIL=admin@cybersensei.io
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD

# --- API Keys ---
ANTHROPIC_API_KEY=
HIBP_API_KEY=
ABUSEIPDB_API_KEY=

# --- Microsoft 365 ---
M365_CLIENT_ID=
M365_CLIENT_SECRET=
M365_REDIRECT_URI=

# --- Stripe ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- Email (SMTP) ---
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=

# --- URLs ---
CORS_ORIGINS=https://app.cybersensei.io,https://cybersensei.io
PLATFORM_API_URL=https://api.cybersensei.io

# --- Ports ---
PLATFORM_API_PORT=3006
PLATFORM_DASHBOARD_PORT=5173
SCANNER_PORT=8003
WEBSITE_PORT=3002

# --- Monitoring (optional) ---
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=CHANGE_ME
