<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="002-create-risk-detections" author="cybersensei">
        <createTable tableName="risk_detections">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="prompt_event_id" type="BIGINT">
                <constraints nullable="false" foreignKeyName="fk_detection_prompt_event" references="prompt_events(id)"/>
            </column>
            <column name="category" type="VARCHAR(50)">
                <constraints nullable="false"/>
            </column>
            <column name="confidence" type="INT">
                <constraints nullable="false"/>
            </column>
            <column name="detection_method" type="VARCHAR(50)"/>
            <column name="matched_pattern" type="VARCHAR(200)"/>
            <column name="data_snippet_redacted" type="VARCHAR(500)"/>
        </createTable>

        <createIndex indexName="idx_risk_detection_event" tableName="risk_detections">
            <column name="prompt_event_id"/>
        </createIndex>
        <createIndex indexName="idx_risk_detection_category" tableName="risk_detections">
            <column name="category"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
