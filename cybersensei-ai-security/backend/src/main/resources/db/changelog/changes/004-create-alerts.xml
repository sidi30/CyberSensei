<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

    <changeSet id="004-create-alerts" author="cybersensei">
        <createTable tableName="alerts">
            <column name="id" type="BIGINT" autoIncrement="true">
                <constraints primaryKey="true" nullable="false"/>
            </column>
            <column name="company_id" type="BIGINT">
                <constraints nullable="false"/>
            </column>
            <column name="user_id" type="BIGINT"/>
            <column name="prompt_event_id" type="BIGINT">
                <constraints foreignKeyName="fk_alert_prompt_event" references="prompt_events(id)"/>
            </column>
            <column name="title" type="VARCHAR(200)">
                <constraints nullable="false"/>
            </column>
            <column name="description" type="VARCHAR(2000)"/>
            <column name="severity" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="status" type="VARCHAR(20)">
                <constraints nullable="false"/>
            </column>
            <column name="created_at" type="TIMESTAMP" defaultValueComputed="CURRENT_TIMESTAMP">
                <constraints nullable="false"/>
            </column>
            <column name="resolved_at" type="TIMESTAMP"/>
            <column name="resolved_by" type="BIGINT"/>
        </createTable>

        <createIndex indexName="idx_alert_company" tableName="alerts">
            <column name="company_id"/>
        </createIndex>
        <createIndex indexName="idx_alert_status" tableName="alerts">
            <column name="status"/>
        </createIndex>
        <createIndex indexName="idx_alert_created" tableName="alerts">
            <column name="created_at"/>
        </createIndex>
    </changeSet>

</databaseChangeLog>
